# Copy this file to .env and fill in the values

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated Telegram chat IDs allowed to manage numbers
# Get your chat ID by messaging @userinfobot
ADMIN_IDS=7073067783

# Path to the SQLite database file (optional — defaults to ./allowed_phones.db)
DB_PATH=./allowed_phones.db

# Port for the API server (optional — defaults to 3001)
PORT=3001
